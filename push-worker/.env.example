# VAPID keys — generate via: npx web-push generate-vapid-keys
# Set them as Cloudflare secrets (not in this file):
#   wrangler secret put VAPID_PUBLIC_KEY
#   wrangler secret put VAPID_PRIVATE_KEY
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:pedro@example.com

# Worker URL after deploy — paste into app.js as PUSH_SERVER_URL
PUSH_SERVER_URL=https://pedro-push.<your-subdomain>.workers.dev
